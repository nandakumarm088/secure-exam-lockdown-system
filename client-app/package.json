{
  "name": "secureexam-client",
  "version": "25.1.0",
  "description": "The SecureExam Client provides a safe environment for conducting secure online exams.",
  "main": "main.js",
  "author": "NK Technologies",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "electron-store": "^10.1.0",
    "luxon": "^3.6.1",
    "node-fetch": "^3.3.2",
    "node-machine-id": "^1.1.12",
    "uuid": "^11.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "electron": "^36.7.0",
    "electron-builder": "^26.0.12",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "build": {
    "appId": "com.secureexam.client",
    "productName": "SecureExam Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!logs",
      {
        "from": "LockdownHelper",
        "to": "LockdownHelper",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "LockdownHelper/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SecureExam Client",
      "installerIcon": "icon.ico"
    }
  }
}
